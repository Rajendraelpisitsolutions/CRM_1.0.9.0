<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.AI.FormRecognizer" Version="4.1.0" />
    <PackageReference Include="ClosedXML" Version="0.105.0" />
    <PackageReference Include="CsvHelper" Version="33.1.0" />
    <PackageReference Include="MailKit" Version="4.14.1" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.2" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.3" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.2" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.2" />
    <PackageReference Include="Microsoft.Graph" Version="5.96.0" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.1.1" />
    <PackageReference Include="Microsoft.Identity.Web.MicrosoftGraph" Version="4.1.1" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.1.1" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" Version="8.17.0" />
    <PackageReference Include="MimeKit" Version="4.14.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
    <PackageReference Include="Sylvan.Data.Csv" Version="1.3.9" />
    <PackageReference Include="Sylvan.Data.Excel" Version="0.5.4" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Azure.AI.FormRecognizer" Condition="Exists('bin\Debug\net8.0\Azure.AI.FormRecognizer.dll')">
      <HintPath>bin\Debug\net8.0\Azure.AI.FormRecognizer.dll</HintPath>
    </Reference>
    <Reference Include="Azure.Core" Condition="Exists('bin\Debug\net8.0\Azure.Core.dll')">
      <HintPath>bin\Debug\net8.0\Azure.Core.dll</HintPath>
    </Reference>
    <Reference Include="ClosedXML" Condition="Exists('bin\Debug\net8.0\ClosedXML.dll')">
      <HintPath>bin\Debug\net8.0\ClosedXML.dll</HintPath>
    </Reference>
    <Reference Include="CsvHelper" Condition="Exists('bin\Debug\net8.0\CsvHelper.dll')">
      <HintPath>bin\Debug\net8.0\CsvHelper.dll</HintPath>
    </Reference>
    <Reference Include="MailKit" Condition="Exists('bin\Debug\net8.0\MailKit.dll')">
      <HintPath>bin\Debug\net8.0\MailKit.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Condition="Exists('bin\Debug\net8.0\Microsoft.AspNetCore.Authentication.JwtBearer.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.AspNetCore.Authentication.JwtBearer.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Condition="Exists('bin\Debug\net8.0\Microsoft.AspNetCore.Authentication.OpenIdConnect.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.AspNetCore.Authentication.OpenIdConnect.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Data.SqlClient" Condition="Exists('bin\Debug\net8.0\Microsoft.Data.SqlClient.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Data.SqlClient.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.EntityFrameworkCore" Condition="Exists('bin\Debug\net8.0\Microsoft.EntityFrameworkCore.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.EntityFrameworkCore.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.EntityFrameworkCore.Abstractions" Condition="Exists('bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Abstractions.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Abstractions.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.EntityFrameworkCore.Design" Condition="Exists('bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Design.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Design.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.EntityFrameworkCore.Relational" Condition="Exists('bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Relational.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.EntityFrameworkCore.Relational.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.EntityFrameworkCore.SqlServer" Condition="Exists('bin\Debug\net8.0\Microsoft.EntityFrameworkCore.SqlServer.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.EntityFrameworkCore.SqlServer.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Graph" Condition="Exists('bin\Debug\net8.0\Microsoft.Graph.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Graph.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Graph.Core" Condition="Exists('bin\Debug\net8.0\Microsoft.Graph.Core.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Graph.Core.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Identity.Web" Condition="Exists('bin\Debug\net8.0\Microsoft.Identity.Web.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Identity.Web.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Identity.Web.MicrosoftGraph" Condition="Exists('bin\Debug\net8.0\Microsoft.Identity.Web.MicrosoftGraph.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Identity.Web.MicrosoftGraph.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.Identity.Web.UI" Condition="Exists('bin\Debug\net8.0\Microsoft.Identity.Web.UI.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.Identity.Web.UI.dll</HintPath>
    </Reference>
    <Reference Include="Microsoft.OpenApi" Condition="Exists('bin\Debug\net8.0\Microsoft.OpenApi.dll')">
      <HintPath>bin\Debug\net8.0\Microsoft.OpenApi.dll</HintPath>
    </Reference>
    <Reference Include="MimeKit" Condition="Exists('bin\Debug\net8.0\MimeKit.dll')">
      <HintPath>bin\Debug\net8.0\MimeKit.dll</HintPath>
    </Reference>
    <Reference Include="Swashbuckle.AspNetCore.Swagger" Condition="Exists('bin\Debug\net8.0\Swashbuckle.AspNetCore.Swagger.dll')">
      <HintPath>bin\Debug\net8.0\Swashbuckle.AspNetCore.Swagger.dll</HintPath>
    </Reference>
    <Reference Include="Swashbuckle.AspNetCore.SwaggerGen" Condition="Exists('bin\Debug\net8.0\Swashbuckle.AspNetCore.SwaggerGen.dll')">
      <HintPath>bin\Debug\net8.0\Swashbuckle.AspNetCore.SwaggerGen.dll</HintPath>
    </Reference>
    <Reference Include="Swashbuckle.AspNetCore.SwaggerUI" Condition="Exists('bin\Debug\net8.0\Swashbuckle.AspNetCore.SwaggerUI.dll')">
      <HintPath>bin\Debug\net8.0\Swashbuckle.AspNetCore.SwaggerUI.dll</HintPath>
    </Reference>
    <Reference Include="Sylvan.Data.Csv" Condition="Exists('bin\Debug\net8.0\Sylvan.Data.Csv.dll')">
      <HintPath>bin\Debug\net8.0\Sylvan.Data.Csv.dll</HintPath>
    </Reference>
    <Reference Include="Sylvan.Data.Excel" Condition="Exists('bin\Debug\net8.0\Sylvan.Data.Excel.dll')">
      <HintPath>bin\Debug\net8.0\Sylvan.Data.Excel.dll</HintPath>
    </Reference>
    <Reference Include="System.IdentityModel.Tokens.Jwt" Condition="Exists('bin\Debug\net8.0\System.IdentityModel.Tokens.Jwt.dll')">
      <HintPath>bin\Debug\net8.0\System.IdentityModel.Tokens.Jwt.dll</HintPath>
    </Reference>
